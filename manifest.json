{
  "manifest_version": 3,
  "name": "Audio Booster",
  "version": "1.0",
  "description": "A professional browser volume booster with stereo panning and flip controls.",

  "permissions": [
    "storage",
    "activeTab"
  ],
  "icons":{
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon.png",
    "128": "assets/icons/icon.png"
  },
  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}